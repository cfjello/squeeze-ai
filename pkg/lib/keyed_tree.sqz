(* ============================================================
   pkg/lib/keyed_tree.sqz  --  Squeeze V13 Keyed Tree Type
   ============================================================

   Defines the keyed_tree.@type type and its methods.
   A keyed_tree is a general tree where every node carries a
   globally-unique key (Â§unique_key) in addition to its value.
   Nodes are directly addressable by key, enabling efficient
   point access, parent lookup, subtree merging, and targeted
   child insertion.

   All methods return new values; none mutate in place.

   Node shape (internal):
       [ key: unique_key, value: @?, children: [] ]

   Tree shape (internal):
       [ type: @?, root: node | null ]

   Key uniqueness is enforced at runtime by the grammar; methods
   here do not re-validate it but rely on the runtime contract.

   Intrinsics used (UPPERCASE builtins):
     TREE_NODE_COUNT<t>              â€” total number of nodes
     TREE_DEPTH<t>                   â€” max depth from root to leaf
     TREE_ROOT_VALUE<t>              â€” value at the root node
     TREE_CHILDREN_COUNT<t>          â€” direct root child count
     TREE_DFS<t>                     â€” array.@type of values in DFS pre-order
     TREE_BFS<t>                     â€” array.@type of values in BFS level-order
     TREE_TO_JSON<t>                 â€” JSON representation
     TREE_TO_STRING<t>               â€” indented text representation
     TREE_GET_NODE<t, key>           â€” full node record for key, or null
     TREE_GET_KEYS<t>                â€” array.@type of every key in the tree (DFS)
     TREE_PARENT_KEY<t, key>         â€” key of parent node, or null if root
     TREE_WITH_CHILD_OF<t, pkey, n>  â€” new tree: node n inserted under pkey
     TREE_WITHOUT_KEY<t, key>        â€” new tree: node (and subtree) removed
     TREE_MERGE<t, other>            â€” new tree: other's root grafted as child
   *)

(col : std.collections.type.@type)  keyed_tree, keyed_tree_final: {
    names, n, 1..m: ["keyed_tree", "keyed_tree_final"]
    map:     col.map
    filter:  col.filter
    first:   col.first
    last:    col.last
    count:   col.count
    collect: col.collect
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ type: @?, root: null ]
        ver,   v:       "v0.0"

        init: <- (
            -> raw: Â§keyed_tree_final
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name,
                 card:  __ps_call LHS Â§assign_lhs.cardinality,
                 type:  $,
                 data:  raw ]
        )
    )


    (* ---------------------------------------------------------------
       Structural inspection
       --------------------------------------------------------------- *)

    (* node_count â€” total number of nodes in the tree. *)
    (t : keyed_tree.@type) node_count: <- (
        <- __ps_proxy TREE_NODE_COUNT <t>
    )

    (* depth â€” maximum depth from root to any leaf.  Root alone = 1. *)
    (t : keyed_tree.@type) depth: <- (
        <- __ps_proxy TREE_DEPTH <t>
    )

    (* is_empty â€” true when the tree has no root node. *)
    (t : keyed_tree.@type) is_empty: <- (
        <- t.data.root == null
    )

    (* root_value â€” the value at the root node. *)
    (t : keyed_tree.@type) root_value: <- (
        <- __ps_proxy TREE_ROOT_VALUE <t>
    )

    (* children_count â€” number of direct children of the root node. *)
    (t : keyed_tree.@type) children_count: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t>
    )

    (* is_leaf â€” true when the root has no children. *)
    (t : keyed_tree.@type) is_leaf: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t> == 0
    )


    (* ---------------------------------------------------------------
       Traversal
       --------------------------------------------------------------- *)

    (* to_depth_first â€” array.@type of node values in DFS pre-order. *)
    (t : keyed_tree.@type) to_depth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_DFS <t> ]
    )

    (* to_breadth_first â€” array.@type of node values in BFS level-order. *)
    (t : keyed_tree.@type) to_breadth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_BFS <t> ]
    )


    (* ---------------------------------------------------------------
       Key-addressed access
       --------------------------------------------------------------- *)

    (* contains_key â€” true if any node in the tree carries key. *)
    (t : keyed_tree.@type) contains_key: <- (
        -> key: @?
        <- __ps_proxy TREE_GET_NODE <t, key> != null
    )

    (* get_node â€” full node record { key, value, children } for key,
       or null when not found. *)
    (t : keyed_tree.@type) get_node: <- (
        -> key: @?
        <- __ps_proxy TREE_GET_NODE <t, key>
    )

    (* get_value â€” value field of the node identified by key, or null. *)
    (t : keyed_tree.@type) get_value: <- (
        -> key: @?
        node = __ps_proxy TREE_GET_NODE <t, key>
        <- ( node == null ) & null ^ node.value
    )

    (* get_keys â€” array.@type of every key present in the tree (DFS order). *)
    (t : keyed_tree.@type) get_keys: <- (
        <- [ type: $, data: __ps_proxy TREE_GET_KEYS <t> ]
    )

    (* parent_key â€” unique_key of the parent of the node identified by key.
       Returns null when key is the root or is not found. *)
    (t : keyed_tree.@type) parent_key: <- (
        -> key: @?
        <- __ps_proxy TREE_PARENT_KEY <t, key>
    )


    (* ---------------------------------------------------------------
       Functional mutation
       --------------------------------------------------------------- *)

    (* with_child â€” new keyed_tree with node appended as a direct child
       of the root.  node must carry a key not yet present in the tree. *)
    (t : keyed_tree.@type) with_child: <- (
        -> node: @?
        <- [ type: $, data: __ps_proxy TREE_WITH_CHILD_OF <t, t.data.root.key, node> ]
    )

    (* with_child_of â€” new keyed_tree with node inserted as a direct child
       of the node identified by parent_key.
       node must carry a key not yet present in the tree. *)
    (t : keyed_tree.@type) with_child_of: <- (
        -> parent_key: @?
        -> node: @?
        <- [ type: $, data: __ps_proxy TREE_WITH_CHILD_OF <t, parent_key, node> ]
    )

    (* without_key â€” new keyed_tree with the node identified by key and its
       entire subtree removed.  Returns the tree unchanged when key is absent. *)
    (t : keyed_tree.@type) without_key: <- (
        -> key: @?
        <- [ type: $, data: __ps_proxy TREE_WITHOUT_KEY <t, key> ]
    )

    (* merge â€” new keyed_tree with other's root grafted as a direct child
       of this tree's root.  All keys across both trees must remain unique;
       the runtime raises an error on conflict. *)
    (t : keyed_tree.@type) merge: <- (
        -> other: keyed_tree.@type
        <- [ type: $, data: __ps_proxy TREE_MERGE <t, other> ]
    )


    (* ---------------------------------------------------------------
       Conversion
       --------------------------------------------------------------- *)

    (* to_json â€” JSON object representation of the full tree. *)
    (t : keyed_tree.@type) to_json: <- (
        <- __ps_proxy TREE_TO_JSON <t>
    )

    (* to_string â€” indented text representation; children indented
       two spaces per level below their parent. *)
    (t : keyed_tree.@type) to_string: <- (
        <- __ps_proxy TREE_TO_STRING <t>
    )
}
