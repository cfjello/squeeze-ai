
(* ============================================================
   pkg/lib/integer.sqz  --  Squeeze V13 Integer Type
   ============================================================

   Defines the integer.@type type and its methods.
   Integers are immutable value types.  Internally the sign and
   the magnitude are stored separately so that the magnitude can
   always be held in the narrowest fitting unsigned type
   (uint8 â†’ uint128).

   Intrinsics used (UPPERCASE builtins):
     CAST string<val>   â€” coerce any value to its decimal string
     TO_JSON<val>       â€” JSON-serialise a single value
     INT_TO_STRING<n, base> â€” convert magnitude to string in given base
   *)

integer, unsigned_int: {
    names, n, 1..m: ["integer", "unsigned_int"]
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ sign: '+', value: 0 ]
        ver,   v:       "v0.0"

        (* init â€” parse a raw integer literal, record the sign separately,
           and store the magnitude in the narrowest fitting unsigned type. *)
        init: <- (
            -> raw: Â§integer
            sign: Â§char '+'
            ( raw < 0 ) & sign: Â§char '-'

            (* magnitude: absolute value *)
            mag: raw
            ( raw < 0 ) & mag: 0 - raw

            (* select narrowest container *)
            ( mag <= 255 )                                      & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, value: uint8   mag ] ]
            ( mag <= 65535 )                                    & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, value: uint16  mag ] ]
            ( mag <= 4294967295 )                               & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, value: uint32  mag ] ]
            ( mag <= 18446744073709551615 )                     & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, value: uint64  mag ] ]
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, value: uint128 mag ] ]
        )
    )


    (* ---------------------------------------------------------------
       Sign and magnitude
       --------------------------------------------------------------- *)

    (* abs â€” magnitude as a non-negative integer. *)
    (n : integer.@type) abs: <- (
        <- [ type: $, data: [ sign: '+', value: n.data.value ] ]
    )

    (* sign â€” returns "+" or "-" as a string. *)
    (n : integer.@type) sign: <- (
        <- __ps_proxy CAST string <n.data.sign>
    )

    (* is_zero â€” true when the value is exactly 0. *)
    (n : integer.@type) is_zero: <- (
        <- n.data.value == 0
    )

    (* is_positive â€” true when value > 0. *)
    (n : integer.@type) is_positive: <- (
        <- n.data.sign == '+' & n.data.value > 0
    )

    (* is_negative â€” true when value < 0. *)
    (n : integer.@type) is_negative: <- (
        <- n.data.sign == '-'
    )


    (* ---------------------------------------------------------------
       Range validation
       --------------------------------------------------------------- *)

    (* in_range â€” true when n falls within the given numeric range. *)
    (n : integer.@type) in_range: <- (
        -> r: Â§func_fixed_num_range
        <- n >< r
    )


    (* ---------------------------------------------------------------
       String conversion
       --------------------------------------------------------------- *)

    (* to_string â€” decimal string representation.
       Positive values are returned without a leading "+". *)
    (n : integer.@type) to_string: <- (
        mag_str: __ps_proxy CAST string <n.data.value>
        ( n.data.sign == '-' ) & <- '-' + mag_str
        <- mag_str
    )

    (* to_string_radix â€” convert to a string in the given base (2, 8, 10, or 16). *)
    (n : integer.@type) to_string_radix: <- (
        -> base: integer
        mag_str: __ps_proxy INT_TO_STRING <n.data.value, base>
        ( n.data.sign == '-' ) & <- '-' + mag_str
        <- mag_str
    )


    (* ---------------------------------------------------------------
       JSON serialisation
       --------------------------------------------------------------- *)

    (* to_json â€” JSON representation (unquoted integer literal). *)
    (n : integer.@type) to_json: <- (
        <- n.to_string()
    )
}
