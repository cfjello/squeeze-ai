(* ============================================================
   pkg/lib/decimal.sqz  --  Squeeze V13 Decimal Type
   ============================================================

   Defines the decimal.@type type and its methods.
   Decimals are fixed-point, immutable value types written as
   sign? digits "." digits (e.g. -3.14, +0.001, 42.0).

   The fractional part is stored as a raw digit string so that
   trailing zeros are preserved and no rounding is applied at
   the library level.  The whole part determines which internal
   container is used:

     decimal8   â€” whole part in  -128..127
     decimal16  â€” whole part in  -32768..32767
     decimal32  â€” whole part in  -2147483648..2147483647
     decimal64  â€” whole part in  -9223372036854775808..9223372036854775807
     decimal128 â€” whole part in  -170141183460469231731687303715884105728
                                  ..170141183460469231731687303715884105727

   Intrinsics used (UPPERCASE builtins):
     CAST string<val>          â€” coerce a value to its string form
     DEC_FLOOR<d>              â€” largest integer <= d
     DEC_CEIL<d>               â€” smallest integer >= d
     DEC_ROUND<d, places>      â€” round to given decimal places
     DEC_TRUNC<d, places>      â€” truncate to given decimal places
     DEC_FRAC_DIGITS<d>        â€” count of digits after the decimal point
   *)

decimal, decimal_num: {
    names,n, 1..2: ["decimal", "decimal_num"]
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ sign: '+', whole: 0, frac: "0" ]
        ver,   v:       "v0.0"

        (* init â€” parse a raw decimal literal.
           The sign and whole part are separated from the fractional string so
           that fixed-point precision is never lost, and the whole part is held
           in the narrowest fitting signed container. *)
        init: <- (
            -> raw: Â§decimal
            sign: Â§char '+'
            ( raw < 0 ) & sign: Â§char '-'

            (* split on the decimal point *)
            whole_part: __ps_proxy DEC_FLOOR <raw>
            ( raw < 0 ) & whole_part: __ps_proxy DEC_CEIL <raw>
            mag_whole:  whole_part
            ( raw < 0 ) & mag_whole: 0 - whole_part

            frac_str: __ps_proxy DEC_FRAC_STR <raw>

            (* select narrowest container by whole-part magnitude *)
            ( mag_whole <= 127 )                   & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, whole: decimal8   whole_part, frac: frac_str ] ]
            ( mag_whole <= 32767 )                 & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, whole: decimal16  whole_part, frac: frac_str ] ]
            ( mag_whole <= 2147483647 )            & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, whole: decimal32  whole_part, frac: frac_str ] ]
            ( mag_whole <= 9223372036854775807 )   & <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, whole: decimal64  whole_part, frac: frac_str ] ]
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name, card: __ps_call LHS Â§assign_lhs.cardinality, type: $, data: [ sign: sign, whole: decimal128 whole_part, frac: frac_str ] ]
        )
    )

} 
    (* ---------------------------------------------------------------
       Sign and parts
       --------------------------------------------------------------- *)

    (* abs â€” magnitude as a non-negative decimal. *)
    (d : decimal.@type) abs: <- (
        <- [ type: $, data: [ sign: '+', whole: d.data.whole, frac: d.data.frac ] ]
    )

    (* sign â€” returns "+" or "-" as a string. *)
    (d : decimal.@type) sign: <- (
        <- __ps_proxy CAST string <d.data.sign>
    )

    (* whole_part â€” integer part as a signed integer (negative when d < 0). *)
    (d : decimal.@type) whole_part: <- (
        <- d.data.whole
    )

    (* frac_part â€” fractional digits as a string, e.g. "14" for 3.14.
       Trailing zeros are preserved. *)
    (d : decimal.@type) frac_part: <- (
        <- d.data.frac
    )

    (* frac_digits â€” number of digits after the decimal point. *)
    (d : decimal.@type) frac_digits: <- (
        <- __ps_proxy DEC_FRAC_DIGITS <d>
    )


    (* ---------------------------------------------------------------
       Predicates
       --------------------------------------------------------------- *)

    (* is_zero â€” true when the value is exactly 0.0 (any number of trailing zeros). *)
    (d : decimal.@type) is_zero: <- (
        <- d.data.whole == 0 & d.data.frac =~ /^0+$/
    )

    (* is_positive â€” true when value > 0. *)
    (d : decimal.@type) is_positive: <- (
        <- d.data.sign == '+' & !d.is_zero()
    )

    (* is_negative â€” true when value < 0. *)
    (d : decimal.@type) is_negative: <- (
        <- d.data.sign == '-'
    )

    (* is_integer â€” true when the fractional part is all zeros (value is a whole number). *)
    (d : decimal.@type) is_integer: <- (
        <- d.data.frac =~ /^0+$/
    )


    (* ---------------------------------------------------------------
       Range validation
       --------------------------------------------------------------- *)

    (* in_range â€” true when d falls within the given numeric range. *)
    (d : decimal.@type) in_range: <- (
        -> r: Â§func_fixed_num_range
        <- d >< r
    )


    (* ---------------------------------------------------------------
       Rounding and truncation
       --------------------------------------------------------------- *)

    (* floor â€” largest integer <= d, returned as an integer. *)
    (d : decimal.@type) floor: <- (
        <- __ps_proxy DEC_FLOOR <d>
    )

    (* ceil â€” smallest integer >= d, returned as an integer. *)
    (d : decimal.@type) ceil: <- (
        <- __ps_proxy DEC_CEIL <d>
    )

    (* round â€” round to the given number of decimal places. *)
    (d : decimal.@type) round: <- (
        -> places: integer
        <- __ps_proxy DEC_ROUND <d, places>
    )

    (* trunc â€” truncate (towards zero) to the given number of decimal places. *)
    (d : decimal.@type) trunc: <- (
        -> places: integer
        <- __ps_proxy DEC_TRUNC <d, places>
    )


    (* ---------------------------------------------------------------
       String conversion
       --------------------------------------------------------------- *)

    (* to_string â€” decimal string representation.
       Positive values are returned without a leading "+". *)
    (d : decimal.@type) to_string: <- (
        whole_str: __ps_proxy CAST string <d.data.whole>
        ( d.data.sign == '-' ) & <- '-' + whole_str + '.' + d.data.frac
        <- whole_str + '.' + d.data.frac
    )

    (* to_string_fixed â€” fixed number of decimal places, zero-padded or rounded. *)
    (d : decimal.@type) to_string_fixed: <- (
        -> places: integer
        rounded: d.round(places)
        <- rounded.to_string()
    )


    (* ---------------------------------------------------------------
       JSON serialisation
       --------------------------------------------------------------- *)

    (* to_json â€” JSON representation (unquoted decimal literal). *)
    (d : decimal.@type) to_json: <- (
        <- d.to_string()
    )

