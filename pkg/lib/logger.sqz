(* ============================================================
   pkg/lib/logger.sqz  â€”  Async structured logger

   Three types are defined here:

     log_target  â€” one output destination (stdout / file / http)
     log_entry   â€” a single structured log record
     logger      â€” multi-target logger with async dispatch queue

   Go codegen mappings (uppercase = codegen intrinsics):
     NOW_ISO8601               â†’ time.Now().UTC().Format(time.RFC3339Nano)
     FILE_SINK<path,fmt,...>   â†’ lumberjack.Logger wrapped in slog.Handler
                                  (file rotation controlled by max_size_mb /
                                   max_age_days / max_backups)
     HTTP_SINK<url,fmt,...>    â†’ buffered chan + goroutine; accumulates entries
                                  up to batch_size then HTTP POST as JSON array
                                  to url with optional Authorization header;
                                  per-request deadline = timeout_ms
     STDOUT_SINK<fmt>          â†’ slog.NewTextHandler(os.Stdout) when fmt="text"
                                  slog.NewJSONHandler(os.Stdout) when fmt="json"
     SINK_FLUSH<tgt>           â†’ write sentinel to target chan, block until the
                                  worker goroutine acknowledges drain via done chan
   ============================================================ *)


(* ============================================================
   log_target  â€”  one output destination
   ============================================================ *)

log_target, lt: {
    names, n, 1..m : ["log_target", "lt"]
    - (
        card,  c       : 1..1
        type,  t       : $
        ver,   v       : "v0.0"
    )

    kind,   k   : "stdout"  (* "stdout" | "file" | "http" *)
    format, fmt : "json"    (* "json" | "text" *)

    (* file target â€” Go: lumberjack.Logger *)
    path         : ""       (* output file path; required when kind = "file" *)
    max_size_mb  : 100      (* rotate after N MiB *)
    max_age_days : 7        (* delete rotated files older than N days *)
    max_backups  : 5        (* keep at most N rotated backup files *)

    (* http(s) target â€” Go: buffered chan + http.Client goroutine *)
    url          : ""       (* https://host/path endpoint; required when kind = "http" *)
    timeout_ms   : 5000     (* per-request timeout in milliseconds *)
    batch_size   : 100      (* flush when queue reaches N entries *)
    auth_header  : ""       (* "Bearer <token>" â€” empty = no auth *)

    - init: <- (
        -> k:   Â§string_quoted,
           fmt: Â§string_quoted,
           p:   Â§string_quoted,
           u:   Â§string_quoted
        k   >< ["stdout", "file", "http"]           (* kind must be one of the three targets *)
        fmt >< ["json", "text"]                     (* format must be json or text *)
        k == "file" & p != ""                       (* file target requires a path *)
        k == "http" & u ~ /^https?:\/\//            (* http target requires a valid url *)
        <- [
            names:        __ps_call LHS Â§assign_lhs.ident_name,
            card:         __ps_call LHS Â§assign_lhs.cardinality,
            type:         $,
            kind:         k,
            format:       fmt,
            path:         p,
            url:          u,
            max_size_mb:  max_size_mb,
            max_age_days: max_age_days,
            max_backups:  max_backups,
            timeout_ms:   timeout_ms,
            batch_size:   batch_size,
            auth_header:  auth_header
        ]
    )

    (* Return a copy with file rotation parameters overridden.
       Go: reconfigure the lumberjack.Logger bound to this target. *)
    (lt : log_target.@type) with_rotation: <- (
        -> size_mb: Â§integer, age_days: Â§integer, backups: Â§integer
        <- [
            type:         $,
            kind:         lt.kind,
            format:       lt.format,
            path:         lt.path,
            url:          lt.url,
            max_size_mb:  size_mb,
            max_age_days: age_days,
            max_backups:  backups,
            timeout_ms:   lt.timeout_ms,
            batch_size:   lt.batch_size,
            auth_header:  lt.auth_header
        ]
    )

    (* Return a copy with HTTP delivery parameters overridden.
       Go: reconfigure the http.Client and batcher goroutine for this target. *)
    (lt : log_target.@type) with_http_opts: <- (
        -> timeout: Â§integer, batch: Â§integer, auth: Â§string_quoted
        <- [
            type:         $,
            kind:         lt.kind,
            format:       lt.format,
            path:         lt.path,
            url:          lt.url,
            max_size_mb:  lt.max_size_mb,
            max_age_days: lt.max_age_days,
            max_backups:  lt.max_backups,
            timeout_ms:   timeout,
            batch_size:   batch,
            auth_header:  auth
        ]
    )
}


(* ============================================================
   log_entry  â€”  one structured log record
   ============================================================ *)

log_entry, le: {
    names, n, 1..m : ["log_entry", "le"]
    - (
        card,  c       : 1..1
        type,  t       : $
        ver,   v       : "v0.0"
    )

    level,     lvl : "info"  (* "debug" | "info" | "warn" | "error" *)
    message,   msg : ""
    timestamp, ts  : ""      (* ISO-8601; injected at init time â€” see NOW_ISO8601 above *)
    fields,    fld : {}      (* arbitrary key-value context â€” Go: []slog.Attr *)
    error_ref, er  : @?      (* optional attached error_event.@type *)

    - init: <- (
        -> lvl: Â§string_quoted,
           msg: Â§string_quoted,
           fld: Â§object_final,
           er:  Â§any_type
        lvl >< ["debug", "info", "warn", "error"]
        <- [
            names:     __ps_call LHS Â§assign_lhs.ident_name,
            card:      __ps_call LHS Â§assign_lhs.cardinality,
            type:      $,
            level:     lvl,
            message:   msg,
            timestamp: __ps_proxy NOW_ISO8601,
            fields:    fld,
            error_ref: er
        ]
    )
}


(* ============================================================
   logger  â€”  async multi-target structured logger

   Async model (Go codegen):
     - Each log_target gets a dedicated buffered channel (size = queue_cap).
     - A worker goroutine per target drains the channel:
         file   â†’ slog writes via lumberjack.Logger (handles rotation)
         http   â†’ accumulates entries; HTTP POST when batch_size reached
                  or a flush sentinel is received
         stdout â†’ slog writes to os.Stdout
     - Callers NEVER block: entries are silently dropped on full channel.
     - flush() sends a sentinel and blocks until the worker acknowledges.
   ============================================================ *)

logger, log: {
    names, n, 1..m : ["logger", "log"]
    - (
        card,  c       : 1..1
        type,  t       : $
        ver,   v       : "v0.0"
    )

    min_level, lvl : "info"  (* minimum level to emit: "debug" | "info" | "warn" | "error" *)
    targets,   tgts: []      (* log_target.@type[] â€” registered output targets *)
    queue_cap       : 4096   (* Go: buffered chan capacity per target â€” never blocks caller *)

    - init: <- (
        -> lvl: Â§string_quoted
        lvl >< ["debug", "info", "warn", "error"]
        <- [
            names:     __ps_call LHS Â§assign_lhs.ident_name,
            card:      __ps_call LHS Â§assign_lhs.cardinality,
            type:      $,
            min_level: lvl,
            targets:   [],
            queue_cap: queue_cap
        ]
    )

    (* Return a new logger with the given target appended.
       Immutable update â€” original logger is unchanged.
       Go: launch a worker goroutine for the new target channel. *)
    (l : logger.@type) add_target: <- (
        -> tgt: log_target.@type
        <- [ type: $, min_level: l.min_level, targets: l.targets + [tgt], queue_cap: l.queue_cap ]
    )

    (* Internal â€” dispatch entry to all registered targets asynchronously.
       Go: non-blocking send on each target's buffered chan; drop silently on full. *)
    (l : logger.@type) _emit: <- (
        -> entry: log_entry.@type
        l.targets >> tgt (
            tgt.next & (
                tgt.kind == "file"   & entry >> __ps_proxy FILE_SINK <tgt.path,   tgt.format, tgt.max_size_mb, tgt.max_age_days, tgt.max_backups>
                tgt.kind == "http"   & entry >> __ps_proxy HTTP_SINK <tgt.url,    tgt.format, tgt.timeout_ms,  tgt.batch_size,   tgt.auth_header>
                tgt.kind == "stdout" & entry >> __ps_proxy STDOUT_SINK <tgt.format>
            )
        )
    )

    (* Log at an explicit level with structured fields.
       The entry is level-gated against min_level before _emit is called.
       Level ordering: debug < info < warn < error. *)
    (l : logger.@type) log: <- (
        -> lvl: Â§string_quoted, msg: Â§string_quoted, fld: Â§object_final
        lvl >< ["debug", "info", "warn", "error"]
        entry: log_entry[ lvl, msg, fld, @? ]
        level_pass: (
            l.min_level == "debug"
            ^ l.min_level == "info"  & lvl >< ["info", "warn", "error"]
            ^ l.min_level == "warn"  & lvl >< ["warn", "error"]
            ^ lvl == "error"
        )
        level_pass & l._emit[ entry ]
    )

    (* Convenience shorthand â€” delegates to log *)

    (l : logger.@type) debug: <- (
        -> msg: Â§string_quoted, fld: Â§object_final
        l.log[ "debug", msg, fld ]
    )

    (l : logger.@type) info: <- (
        -> msg: Â§string_quoted, fld: Â§object_final
        l.log[ "info", msg, fld ]
    )

    (l : logger.@type) warn: <- (
        -> msg: Â§string_quoted, fld: Â§object_final
        l.log[ "warn", msg, fld ]
    )

    (* error variant also accepts an optional error_event.@type for structured capture *)
    (l : logger.@type) error: <- (
        -> msg: Â§string_quoted, fld: Â§object_final, er: error_event.@type
        entry: log_entry[ "error", msg, fld, er ]
        l._emit[ entry ]
    )

    (* Flush â€” drain all target queues synchronously.
       Go: write sentinel on each chan, block until worker ACK via done chan. *)
    (l : logger.@type) flush: <- (
        l.targets >> tgt (
            tgt.next & __ps_proxy SINK_FLUSH <tgt>
        )
    )
}
