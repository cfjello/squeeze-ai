
<squeeze base library, base: 

(* int 8 is a function that stakes a set of digits as argument, checks the range, the min and max allowed, and returns a int8 typed object *)
int8, signed byte: <-(  
    @name : "int8"
    -> arg : "" 
    <-( arg >= -128 &  arg <= 127 ) & 
        { 
            @type: $
            @value: arg
        }
    )
>