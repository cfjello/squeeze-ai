(* ============================================================
   pkg/lib/bitfield.sqz  --  Squeeze V13 Bitfield Type
   ============================================================

   Defines the bitfield.@type type and its methods.
   A bitfield is a fixed-width set of named binary flags packed
   into one unsigned integer.  The base type (uint8..uint64)
   determines the maximum flag capacity.

   Grammar declares a bitfield schema via:
       Perms : BITFIELD uint8 [ read: 0, write: 1, exec: 2 ]

   The grammar comment shows runtime OR like `Perms.read | Perms.write`
   but Squeeze has no bitwise operators.  All bit operations are
   method calls backed by intrinsics.

   Each flag declaration binds a name to a zero-based bit position.
   A uint8 position value covers all valid positions for all base types
   (max position for uint64 is 63, which fits uint8 0..255 comfortably).
   No cast from position to base type is needed in .sqz code â€” the
   intrinsic always operates using the base type's full width.

   All methods return new values; none mutate in place.

   Internal representation:
     [ base: "uint8"|"uint16"|"uint32"|"uint64",
       flags: array.@type of { name: string, position: uint8 },
       value: uint64 ]   (* value always stored as uint64 internally;
                            the base type constrains which bits are valid *)

   Intrinsics used (UPPERCASE builtins):
     BF_MAX_BITS<b>              â€” 8|16|32|64 from base string b
     BF_IS_SET<bf, name>         â€” boolean: named flag bit is 1
     BF_IS_ALL<bf>               â€” boolean: every declared flag is set
     BF_SET<bf, name>            â€” new value with named bit forced to 1
     BF_CLEAR<bf, name>          â€” new value with named bit forced to 0
     BF_TOGGLE<bf, name>         â€” new value with named bit flipped
     BF_UNION<bf1, bf2>          â€” new value: bits set in either (OR)
     BF_INTERSECT<bf1, bf2>      â€” new value: bits set in both (AND)
     BF_DIFFERENCE<bf1, bf2>     â€” new value: bits in bf1 but not bf2 (AND NOT)
     BF_COMPLEMENT<bf>           â€” new value: declared bits inverted (NOT, bounded)
     BF_ACTIVE_FLAGS<bf>         â€” array.@type of names of all set flags
     BF_OF<bf, names>            â€” new value with exactly named flags set
     BF_MASK_OF<bf, name>        â€” new value with only the named flag bit set
     BF_HAS_FLAG<bf, name>       â€” boolean: name is a declared flag
     BF_TO_UINT<bf>              â€” packed raw value as uint64
     BF_TO_JSON<bf>              â€” JSON { base, value, active: [...] }
     BF_TO_STRING<bf>            â€” "read | write" active flag names
   *)

(col : std.collections.type.@type)  bitfield, bitfield_final: {
    names, n, 1..2: ["bitfield", "bitfield_final"]
    filter:  col.filter
    count:   col.count
    collect: col.collect
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ base: Â§bit_field_final, flags: [], value: 0 ]
        ver,   v:       "v0.0"

        init: <- (
            -> raw: Â§bitfield_final
            <- [ names: ps_call LHS Â§assign_lhs.ident_name,
                 card:  ps_call LHS Â§assign_lhs.cardinality,
                 type:  $,
                 data:  raw ]
        )
    )


    (* ---------------------------------------------------------------
       Schema inspection
       --------------------------------------------------------------- *)

    (* flag_names â€” array.@type of all declared flag name strings. *)
    (b : bitfield.@type) flag_names: <- (
        result = []
        >> f: b.data.flags
            -> elem: @?
            result = result + [ f.name ]
        <- [ type: $, data: result ]
    )

    (* flag_count â€” number of declared flags. *)
    (b : bitfield.@type) flag_count: <- (
        <- __ps_proxy LENGTH <b.data.flags>
    )

    (* base_type â€” "uint8", "uint16", "uint32", or "uint64". *)
    (b : bitfield.@type) base_type: <- (
        <- b.data.base
    )

    (* max_bits â€” maximum number of flag bits available: 8, 16, 32, or 64. *)
    (b : bitfield.@type) max_bits: <- (
        <- __ps_proxy BF_MAX_BITS <b.data.base>
    )

    (* has_flag â€” true if name is a declared flag in this bitfield schema. *)
    (b : bitfield.@type) has_flag: <- (
        -> name: string
        <- __ps_proxy BF_HAS_FLAG <b, name>
    )


    (* ---------------------------------------------------------------
       Value inspection
       --------------------------------------------------------------- *)

    (* is_set â€” true if the named flag bit is currently 1. *)
    (b : bitfield.@type) is_set: <- (
        -> name: string
        <- __ps_proxy BF_IS_SET <b, name>
    )

    (* is_clear â€” true if the named flag bit is currently 0. *)
    (b : bitfield.@type) is_clear: <- (
        -> name: string
        <- ( __ps_proxy BF_IS_SET <b, name> ) & false ^ true
    )

    (* active_flags â€” array.@type of names of all flags that are currently set. *)
    (b : bitfield.@type) active_flags: <- (
        <- [ type: $, data: __ps_proxy BF_ACTIVE_FLAGS <b> ]
    )

    (* is_none â€” true if no flag bits are set (packed value == 0). *)
    (b : bitfield.@type) is_none: <- (
        <- b.data.value == 0
    )

    (* is_all â€” true if every declared flag bit is set. *)
    (b : bitfield.@type) is_all: <- (
        <- __ps_proxy BF_IS_ALL <b>
    )


    (* ---------------------------------------------------------------
       Single-flag mutation
       --------------------------------------------------------------- *)

    (* set â€” new bitfield with the named flag bit forced to 1. *)
    (b : bitfield.@type) set: <- (
        -> name: string
        <- [ type: $, data: __ps_proxy BF_SET <b, name> ]
    )

    (* clear â€” new bitfield with the named flag bit forced to 0. *)
    (b : bitfield.@type) clear: <- (
        -> name: string
        <- [ type: $, data: __ps_proxy BF_CLEAR <b, name> ]
    )

    (* toggle â€” new bitfield with the named flag bit flipped. *)
    (b : bitfield.@type) toggle: <- (
        -> name: string
        <- [ type: $, data: __ps_proxy BF_TOGGLE <b, name> ]
    )


    (* ---------------------------------------------------------------
       Multi-flag / bitwise operations
       These replace the | & ~ operators that are absent in Squeeze.
       Both operands must share the same schema (base type and flag declarations).
       --------------------------------------------------------------- *)

    (* union â€” new bitfield with bits set in either self or other (OR).
       Equivalent to the grammar comment `Perms.read | Perms.write`. *)
    (b : bitfield.@type) union: <- (
        -> other: bitfield.@type
        <- [ type: $, data: __ps_proxy BF_UNION <b, other> ]
    )

    (* intersect â€” new bitfield with bits set in both self and other (AND). *)
    (b : bitfield.@type) intersect: <- (
        -> other: bitfield.@type
        <- [ type: $, data: __ps_proxy BF_INTERSECT <b, other> ]
    )

    (* difference â€” new bitfield with bits set in self but not in other (AND NOT). *)
    (b : bitfield.@type) difference: <- (
        -> other: bitfield.@type
        <- [ type: $, data: __ps_proxy BF_DIFFERENCE <b, other> ]
    )

    (* complement â€” new bitfield with every declared flag bit inverted (NOT).
       Only bits that correspond to a declared flag are affected; all other
       bits remain 0 regardless of the base type width. *)
    (b : bitfield.@type) complement: <- (
        <- [ type: $, data: __ps_proxy BF_COMPLEMENT <b> ]
    )


    (* ---------------------------------------------------------------
       Convenience constructors
       These return a new bitfield instance sharing the same schema
       but with a freshly computed value.
       --------------------------------------------------------------- *)

    (* none â€” new instance with all bits cleared (value == 0). *)
    (b : bitfield.@type) none: <- (
        <- [ type: $, data: [ base: b.data.base, flags: b.data.flags, value: 0 ] ]
    )

    (* all â€” new instance with every declared flag bit set. *)
    (b : bitfield.@type) all: <- (
        <- [ type: $, data: __ps_proxy BF_OF <b, __ps_proxy BF_ACTIVE_FLAGS <__ps_proxy BF_COMPLEMENT <b.none>>> ]
    )

    (* of â€” new instance with exactly the named flags set, all others cleared.
       names is an array.@type of flag name strings. *)
    (b : bitfield.@type) of: <- (
        -> names: @?
        <- [ type: $, data: __ps_proxy BF_OF <b, names> ]
    )

    (* mask_of â€” new instance with only the single named flag bit set.
       Useful as a standalone mask value for manual intersect/union work. *)
    (b : bitfield.@type) mask_of: <- (
        -> name: string
        <- [ type: $, data: __ps_proxy BF_MASK_OF <b, name> ]
    )


    (* ---------------------------------------------------------------
       Conversion
       --------------------------------------------------------------- *)

    (* to_uint â€” raw packed value as uint64 integer. *)
    (b : bitfield.@type) to_uint: <- (
        <- __ps_proxy BF_TO_UINT <b>
    )

    (* to_json â€” JSON object: { "base": "uint8", "value": 3, "active": ["read","write"] } *)
    (b : bitfield.@type) to_json: <- (
        <- __ps_proxy BF_TO_JSON <b>
    )

    (* to_string â€” active flag names joined by " | ", e.g. "read | write".
       Returns "" when no flags are set. *)
    (b : bitfield.@type) to_string: <- (
        <- __ps_proxy BF_TO_STRING <b>
    )
}
