int8, signed_byte: <- {  
        @data : [
            @typeName : "int8"
            @type, t: $
        ]

            -> a §digits 
        set: ( a >= -128 &  a <= 127 ) 
        & <- [ 
            name, n: "int8"
            type, t: $
            version, v: "0.0"
        ]
}

    (* Add methods *) 
    ( t @int8@type[] ) sum: <- {
        r = 0; i = 0 
        >> t ( r += t[i++] ) 
    }
}

Squeeze Basic Types, sbt: {
    type_enum: [  "@type" , "@typeName", @version, "@value"  ]

    infer: { -> val any 
             <- val.@type 
           }


}

(sbt) squeeze_array = {
    type_enum: [  "@type" , "@typeName", @version, "@init", "@parent"  ]

    (*
        we need:
            values: we can infer the type
            parent: any kind of collection, could be object or array, we have a reference. 

            - a column header and a object to represent the type - be aware that each column value also have types.
              The real type: collection type -> entry_type

    
    *)
    array_t = [ ref:$, name:"array", ver = "v0", init = [] ]

    

    ( array_t) set: { -> Input Values, v , 1..m: §array_final

                      
                      <- [
                        parent_type: §array_final
                        type: v[1].@type

                      ]}
    
    






}

