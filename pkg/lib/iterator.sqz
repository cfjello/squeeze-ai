
(*
table_header         = UNIFORM string<( array_uniform | TYPE_OF array_uniform<ident_ref> )>;
table_row            = array_final | object_final;
table_objects        = UNIFORM INFER<table_row  { "," table_row }>; 
table_init           = table_header table_objects | object_final; (* object_final deliver both the table_header names and the first table_row *)
table_ins_tail       = "+" ( TYPE_OF table_row<ident_ref> | table_row )  { "+" ( TYPE_OF table_row<ident_ref> | table_row ) };
table_final          = ( TYPE_OF table_init<ident_ref> | table_init ) table_ins_tail { table_ins_tail };
*)


