fetch_01: {
    list : string[]
    fn_stream = <- (   
         response << https://.....
        << ( response.next & <- { next: true, value: response.value } ^  { next: false, value: null } )
    )

    fn_stream >> ( -> item ;  item.next & response.value )
}


iterarate_01: {
    input : infer [ 1,2,3,4,5,6,7]  (* Type is int8[])
    sum = 0 
    input >> inp ( inp.next & sum += inp ^ <- sum )
