(* ============================================================
   pkg/lib/array.sqz  --  Squeeze V13 Array Type
   ============================================================

   Defines the array.@type type and its 1-based positional methods.
   Arrays are uniform (all elements share the same type.@type) and
   value-typed: every method returns a new array; none mutate
   in place.  Elements are indexed from 1.

   For collection-generic operations (map, filter, reduce, â€¦) that
   work on any iterator, see pkg/lib/collections.sqz.

   Intrinsics used (UPPERCASE builtins):
     LENGTH<arr>                 â€” element count
     SUB_RANGE start..end<arr>   â€” positional slice (1-based, inclusive)
     ARRAY_REVERSE<arr>          â€” reverse-order copy
     CAST string<val>            â€” coerce any value to its string form
     TO_JSON<val>                â€” JSON-serialise a single value
   *)

(col : std.collections.type.@type)  array, array_final : {
    names,n , 1..2: ["array", "array_final"]
    _: col
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       @?     (* raw uniform array; assigned by init from Â§array_final *)
        ver,   v:       "v0.0"

        init: <- (
            -> raw: @?
            
            cnt = 0 
            len: raw >> cnt++

            
            raw.@type == $ ( 
                raw.length > 1 &  (
                    type: raw[1].type.@type 
                    data: raw
                ) ^ (
                    type: raw.@type
                    data: [ raw ]
                )
            ) 
            <- [ names: __ps_call §assign_lhs.ident_name,
                card:  __ps_call LHS §assign_lhs.cardinality,
                length: len,
                type:  array.raw.type.@type
                data:  __ps_proxy CAST raw.@type <raw> 
            ]
        )
    )
}


    (* ---------------------------------------------------------------
       O(1) access
       --------------------------------------------------------------- *)

    (* length â€” number of elements *)
    (arr : array.@type) set_length: <- (
         cnt = 0 
         len: arr.data >> cnt++
         arr.length = cnt
        <- cnt 
    )

    (* first â€” element at index 1; null when the array is empty *)
    (arr : array.@type) first: <- (
        ( arr.length > 0 ) & <- arr.data[1]
        <- null
    )

    (* last â€” element at the final index; null when the array is empty *)
    (arr : array.@type) last: <- (
        ( arr.length > 0 ) & <- arr.data[arr.length]
        <- null
    )


    (* ---------------------------------------------------------------
       Slicing
       --------------------------------------------------------------- *)

    (* sub_array â€” new array.@type from start to end (1-based, inclusive).
       Negative indices count from the end: -1 is the last element.
       Returns nothing (no-op) when the range falls outside bounds. *)
    (arr : array.@type) sub_array: <- (
        -> start: integer
        -> end:   integer
        n:     arr.length
        start <= 0 & start = n + start
        end   <= 0 & end   = n + end
        valid: 1..n
        start >< valid & end >< valid & (
            sub_array = array []
            idx = start 
            start..end >> (
                sub_array += arr.data[idx++]
            )
            <- arr.init sub_array
        )
    ) 
    
    (* 
    Exception commented out for now: ^ (
        (* exception handling *) 
        -> exceptions.@type: @?        
        exceptions >> (
            -> ex : @?

            (* Do Nothing for now *) 

        )
    )
    *) 

    (* sub_array_range â€” convenience form that accepts a 1-based range literal,
       e.g. arr.sub_array_range(2..5).
       Unpacks the range into its lo and hi endpoints and delegates entirely to
       sub_array, which owns all bounds-checking and negative-index handling. *)
    (arr : array.@type) sub_array_range: <- (
        -> r: Â§func_fixed_num_range
        <- arr.sub_array(r.lo, r.hi)
    )


    (* ---------------------------------------------------------------
       Search
       --------------------------------------------------------------- *)

    (* index_of â€” index of the match_group matching element, or 0
       when absent.  Linear scan: O(n). *)
    (arr : array.@type) index_of: <- (
        -> value: arr.type, match_group: integer 1
        i  = 0
        mg = 1 
        arr.data >> (
            -> elem: arr.type
            i +: 1
            ( elem == value & match_group == mg ) & <- i ^ mg++
        )
        <- 0
    )

    (* contains â€” true when value is present in the array. *)
    (arr : array.@type) contains: <- (
        -> value: arr.type
        <- arr.index_of(value) > 0
    )


    (* ---------------------------------------------------------------
       Reordering
       --------------------------------------------------------------- *)

    (* reverse â€” new array.@type with elements in reverse order. *)
    (arr : array.@type) reverse: <- (
        start = arr.length 
        range = arr.length..1

        rev_arr = []
        range >> (
            -> idx : integer
            rev_arr += arr[idx]
        )

        <- arr.init rev_arr
    )

    (* ---------------------------------------------------------------
       Serialisation
       --------------------------------------------------------------- *)

    (* to_string â€” every element coerced to string and joined with sep.
       Distinct from collections.join, which requires the input to be a
       collection of strings.  Uses CAST string<elem> for coercion. *)
    (arr : array.@type) to_string: <- (
        -> sep: string ","
        result = ""
        first  = true
        arr.data >> (
            -> elem: arr.type
            sep_now = first & "" ^ sep
            ( first ) & first = false
            result += sep_now + __ps_proxy CAST string <elem>
        )
        <- result
    )

    (* to_json â€” JSON array string: "[v1, v2, ...]". *) 
    (arr : array.@type) to_json: <- (
        result = "["
        first  = true
        arr.data >> (
            -> elem: @?
            sep_now = first & "" ^ ", "
            ( first ) & first = false
            result = result + sep_now + __ps_proxy TO_JSON <elem>
        )
        result = result + "]"
        <- result
    )
