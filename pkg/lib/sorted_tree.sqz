(* ============================================================
   pkg/lib/sorted_tree.sqz  --  Squeeze V13 Sorted Tree Type
   ============================================================

   Defines the sorted_tree.@type type and its methods.
   A sorted_tree is a keyed tree where the key type is restricted to
   the sortable subset of Â§unique_key â€” types that have a total order.
   Excluded: uuid_v4, nano_id, hash_key (no natural ordering).
   Allowed:  integer_key, string_key, timestamp_key, sequence_key, etc.

   The invariant maintained by every mutation method is that siblings
   are ordered ascending by key.  This makes the structure suitable
   for BSTs, B-trees, ordered indexes, and priority queues.

   All methods return new values; none mutate in place.

   Node shape (internal):
       [ key: sortable_key, value: @?, children: [] ]
       (children are kept sorted ascending by key at all times)

   Tree shape (internal):
       [ type: @?, root: node | null ]

   Intrinsics used (UPPERCASE builtins):
     TREE_NODE_COUNT<t>              â€” total number of nodes
     TREE_DEPTH<t>                   â€” max depth from root to leaf
     TREE_ROOT_VALUE<t>              â€” value at the root node
     TREE_CHILDREN_COUNT<t>          â€” direct root child count
     TREE_DFS<t>                     â€” array.@type of values in DFS pre-order
     TREE_BFS<t>                     â€” array.@type of values in BFS level-order
     TREE_GET_NODE<t, key>           â€” full node record for key, or null
     TREE_GET_KEYS<t>                â€” array.@type of every key in the tree (DFS)
     TREE_PARENT_KEY<t, key>         â€” key of parent node, or null if root
     TREE_TO_JSON<t>                 â€” JSON representation
     TREE_TO_STRING<t>               â€” indented text representation
     STREE_SEARCH<t, key>            â€” value for key; performs ordered search
     STREE_MIN_KEY<t>                â€” smallest key across the whole tree
     STREE_MAX_KEY<t>                â€” largest key across the whole tree
     STREE_RANGE<t, lo, hi>          â€” array.@type of values whose keys are lo..hi
     STREE_SUCCESSOR<t, key>         â€” key of next-larger node, or null
     STREE_PREDECESSOR<t, key>       â€” key of next-smaller node, or null
     STREE_WITH_NODE<t, node>        â€” new tree: node inserted maintaining sort
     STREE_WITHOUT_KEY<t, key>       â€” new tree: node removed maintaining sort
   *)

(col : std.collections.type.@type)  sorted_tree, sorted_tree_final: {
    names, n, 1..m: ["sorted_tree", "sorted_tree_final"]
    map:     col.map
    filter:  col.filter
    first:   col.first
    last:    col.last
    min:     col.min
    max:     col.max
    count:   col.count
    collect: col.collect
    take:    col.take
    drop:    col.drop
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ type: @?, root: null ]
        ver,   v:       "v0.0"

        init: <- (
            -> raw: Â§sorted_tree_final
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name,
                 card:  __ps_call LHS Â§assign_lhs.cardinality,
                 type:  $,
                 data:  raw ]
        )
    )


    (* ---------------------------------------------------------------
       Structural inspection
       --------------------------------------------------------------- *)

    (* node_count â€” total number of nodes in the tree. *)
    (t : sorted_tree.@type) node_count: <- (
        <- __ps_proxy TREE_NODE_COUNT <t>
    )

    (* depth â€” maximum depth from root to any leaf.  Root alone = 1. *)
    (t : sorted_tree.@type) depth: <- (
        <- __ps_proxy TREE_DEPTH <t>
    )

    (* is_empty â€” true when the tree has no root node. *)
    (t : sorted_tree.@type) is_empty: <- (
        <- t.data.root == null
    )

    (* root_value â€” the value at the root node. *)
    (t : sorted_tree.@type) root_value: <- (
        <- __ps_proxy TREE_ROOT_VALUE <t>
    )

    (* children_count â€” number of direct children of the root node. *)
    (t : sorted_tree.@type) children_count: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t>
    )

    (* is_leaf â€” true when the root has no children. *)
    (t : sorted_tree.@type) is_leaf: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t> == 0
    )


    (* ---------------------------------------------------------------
       Traversal
       --------------------------------------------------------------- *)

    (* to_depth_first â€” array.@type of node values in DFS pre-order. *)
    (t : sorted_tree.@type) to_depth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_DFS <t> ]
    )

    (* to_breadth_first â€” array.@type of node values in BFS level-order. *)
    (t : sorted_tree.@type) to_breadth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_BFS <t> ]
    )


    (* ---------------------------------------------------------------
       Key-addressed access (shared with keyed_tree.@type)
       --------------------------------------------------------------- *)

    (* contains_key â€” true if any node in the tree carries key. *)
    (t : sorted_tree.@type) contains_key: <- (
        -> key: @?
        <- __ps_proxy TREE_GET_NODE <t, key> != null
    )

    (* get_node â€” full node record { key, value, children } for key,
       or null when not found. *)
    (t : sorted_tree.@type) get_node: <- (
        -> key: @?
        <- __ps_proxy TREE_GET_NODE <t, key>
    )

    (* get_value â€” value field of the node identified by key, or null. *)
    (t : sorted_tree.@type) get_value: <- (
        -> key: @?
        node = __ps_proxy TREE_GET_NODE <t, key>
        <- ( node == null ) & null ^ node.value
    )

    (* get_keys â€” array.@type of every key present in the tree (DFS order). *)
    (t : sorted_tree.@type) get_keys: <- (
        <- [ type: $, data: __ps_proxy TREE_GET_KEYS <t> ]
    )

    (* parent_key â€” sortable_key of the parent of the node identified by key.
       Returns null when key is the root or is not found. *)
    (t : sorted_tree.@type) parent_key: <- (
        -> key: @?
        <- __ps_proxy TREE_PARENT_KEY <t, key>
    )


    (* ---------------------------------------------------------------
       Order-exploiting search
       --------------------------------------------------------------- *)

    (* search â€” value associated with key using an order-aware traversal
       (e.g., binary search within each sibling list).
       Returns null when key is absent. *)
    (t : sorted_tree.@type) search: <- (
        -> key: @?
        <- __ps_proxy STREE_SEARCH <t, key>
    )

    (* min_key â€” smallest key across all nodes in the tree. *)
    (t : sorted_tree.@type) min_key: <- (
        <- __ps_proxy STREE_MIN_KEY <t>
    )

    (* max_key â€” largest key across all nodes in the tree. *)
    (t : sorted_tree.@type) max_key: <- (
        <- __ps_proxy STREE_MAX_KEY <t>
    )

    (* range_values â€” array.@type of values whose keys satisfy lo <= key <= hi.
       Result is ordered by key ascending. *)
    (t : sorted_tree.@type) range_values: <- (
        -> lo: @?
        -> hi: @?
        <- [ type: $, data: __ps_proxy STREE_RANGE <t, lo, hi> ]
    )

    (* successor â€” the immediately larger key after key in the tree,
       or null when key is the maximum or is not present. *)
    (t : sorted_tree.@type) successor: <- (
        -> key: @?
        <- __ps_proxy STREE_SUCCESSOR <t, key>
    )

    (* predecessor â€” the immediately smaller key before key in the tree,
       or null when key is the minimum or is not present. *)
    (t : sorted_tree.@type) predecessor: <- (
        -> key: @?
        <- __ps_proxy STREE_PREDECESSOR <t, key>
    )


    (* ---------------------------------------------------------------
       Functional mutation  (sort invariant maintained by runtime)
       --------------------------------------------------------------- *)

    (* with_node â€” new sorted_tree with node inserted at the correct
       sorted position among its siblings.
       node must carry a key not yet present in the tree. *)
    (t : sorted_tree.@type) with_node: <- (
        -> node: @?
        <- [ type: $, data: __ps_proxy STREE_WITH_NODE <t, node> ]
    )

    (* without_key â€” new sorted_tree with the node identified by key and
       its entire subtree removed.  Sort order is preserved.
       Returns the tree unchanged when key is absent. *)
    (t : sorted_tree.@type) without_key: <- (
        -> key: @?
        <- [ type: $, data: __ps_proxy STREE_WITHOUT_KEY <t, key> ]
    )


    (* ---------------------------------------------------------------
       Conversion
       --------------------------------------------------------------- *)

    (* to_json â€” JSON object representation of the full tree. *)
    (t : sorted_tree.@type) to_json: <- (
        <- __ps_proxy TREE_TO_JSON <t>
    )

    (* to_string â€” indented text representation; children indented
       two spaces per level below their parent. *)
    (t : sorted_tree.@type) to_string: <- (
        <- __ps_proxy TREE_TO_STRING <t>
    )
}
