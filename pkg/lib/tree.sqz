(* ============================================================
   pkg/lib/tree.sqz  --  Squeeze V13 General Tree Type
   ============================================================

   Defines the tree.@type type and its methods.
   A tree is a directed acyclic structure with a single root node.
   Each node holds any tree_value and zero or more child nodes.
   Type homogeneity across nodes is a runtime contract, not enforced
   here â€” use @? to allow any type explicitly.

   All methods return new values; none mutate in place.
   Stream iteration: tree nodes are iterable with >>; collection-
   generic operations in collections.sqz apply without duplication here.

   Node shape (internal):  [ value: @?, children: [] ]
   Tree shape (internal):  [ type: @?, root: node | null ]

   Intrinsics used (UPPERCASE builtins):
     TREE_NODE_COUNT<t>           â€” total number of nodes
     TREE_DEPTH<t>                â€” max depth from root to any leaf
     TREE_ROOT_VALUE<t>           â€” value at the root node
     TREE_CHILDREN_COUNT<t>       â€” number of direct root children
     TREE_DFS<t>                  â€” array.@type of values in DFS pre-order
     TREE_BFS<t>                  â€” array.@type of values in BFS level-order
     TREE_FIND<t, pred>           â€” first DFS value matching pred, or null
     TREE_FIND_ALL<t, pred>       â€” array.@type of all values matching pred
     TREE_MAP<t, fn>              â€” new tree: every value transformed by fn
     TREE_WITH_CHILD<t, node>     â€” new tree: node appended as root child
     TREE_PRUNE<t, pred>          â€” new tree: subtrees removed where pred matches
     TREE_TO_JSON<t>              â€” JSON representation
     TREE_TO_STRING<t>            â€” indented text representation
   *)

(col : std.collections.type.@type)  tree, tree_final: {
    names, n, 1..m: ["tree", "tree_final"]
    map:     col.map
    filter:  col.filter
    count:   col.count
    collect: col.collect
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ type: @?, root: null ]
        ver,   v:       "v0.0"

        init: <- (
            -> raw: Â§tree_final
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name,
                 card:  __ps_call LHS Â§assign_lhs.cardinality,
                 type:  $,
                 data:  raw ]
        )
    )


    (* ---------------------------------------------------------------
       Structural inspection
       --------------------------------------------------------------- *)

    (* node_count â€” total number of nodes in the tree. *)
    (t : tree.@type) node_count: <- (
        <- __ps_proxy TREE_NODE_COUNT <t>
    )

    (* depth â€” maximum depth from root to any leaf.  Root alone = 1. *)
    (t : tree.@type) depth: <- (
        <- __ps_proxy TREE_DEPTH <t>
    )

    (* is_empty â€” true when the tree has no root node. *)
    (t : tree.@type) is_empty: <- (
        <- t.data.root == null
    )

    (* root_value â€” the value held at the root node. *)
    (t : tree.@type) root_value: <- (
        <- __ps_proxy TREE_ROOT_VALUE <t>
    )

    (* children_count â€” number of direct children of the root node. *)
    (t : tree.@type) children_count: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t>
    )

    (* is_leaf â€” true when the root has no children. *)
    (t : tree.@type) is_leaf: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t> == 0
    )


    (* ---------------------------------------------------------------
       Traversal
       --------------------------------------------------------------- *)

    (* to_depth_first â€” array.@type of node values in DFS pre-order.
       Root is always first; leaves are last within each subtree. *)
    (t : tree.@type) to_depth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_DFS <t> ]
    )

    (* to_breadth_first â€” array.@type of node values in BFS level-order.
       Root is first; all children of a node precede their grandchildren. *)
    (t : tree.@type) to_breadth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_BFS <t> ]
    )


    (* ---------------------------------------------------------------
       Search
       --------------------------------------------------------------- *)

    (* find â€” first value (DFS) for which predicate returns true, or null. *)
    (t : tree.@type) find: <- (
        -> predicate: @?
        <- __ps_proxy TREE_FIND <t, predicate>
    )

    (* find_all â€” array.@type of all values for which predicate returns true, DFS order. *)
    (t : tree.@type) find_all: <- (
        -> predicate: @?
        <- [ type: $, data: __ps_proxy TREE_FIND_ALL <t, predicate> ]
    )


    (* ---------------------------------------------------------------
       Functional mutation
       --------------------------------------------------------------- *)

    (* with_child â€” new tree with node appended as a direct child of the root.
       Mirrors the grammar's + operator. *)
    (t : tree.@type) with_child: <- (
        -> node: @?
        <- [ type: $, data: __ps_proxy TREE_WITH_CHILD <t, node> ]
    )

    (* map â€” new tree with every node value replaced by fn(value).
       Tree structure (parent-child relationships) is preserved exactly. *)
    (t : tree.@type) map: <- (
        -> fn: @?
        <- [ type: $, data: __ps_proxy TREE_MAP <t, fn> ]
    )

    (* prune â€” new tree with every subtree removed whose root value
       satisfies predicate.  The matched node and all its descendants
       are excluded from the result. *)
    (t : tree.@type) prune: <- (
        -> predicate: @?
        <- [ type: $, data: __ps_proxy TREE_PRUNE <t, predicate> ]
    )


    (* ---------------------------------------------------------------
       Conversion
       --------------------------------------------------------------- *)

    (* to_json â€” JSON object representation of the full tree. *)
    (t : tree.@type) to_json: <- (
        <- __ps_proxy TREE_TO_JSON <t>
    )

    (* to_string â€” indented text representation; children are indented
       two spaces per level below their parent. *)
    (t : tree.@type) to_string: <- (
        <- __ps_proxy TREE_TO_STRING <t>
    )
}
