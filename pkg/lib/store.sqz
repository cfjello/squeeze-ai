(* ============================================================
   pkg/lib/store.sqz  --  Squeeze V13 Versioned Key-Value Store
   ============================================================

   Implements a functional, versioned key-value store.
   Every mutating method returns a new store.@type value; the caller
   replaces its own reference â€” no in-place mutation.  This
   is idiomatic Squeeze and maps cleanly onto the language's
   immutable value model.

   Requires:
     hmap.sqz  â€” heterogeneous string-keyed map  (hmap.@type)

   Design
   ------
   Each named slot holds multiple immutable versioned snapshots,
   identified by UUIDv7 store_ids (time-ordered, sortable).
   Three hmap.@type fields keep all state flat â€” no nested mutation:

     current_ids   name  â†’ store_id          (most-recently stored)
     versions      store_id â†’ [ data: @? ]   (one entry per snapshot)
     name_ids      name  â†’ array.@type            (store_ids, newest first)

   A snapshot's lifetime is the lifetime of the store.@type value that
   holds it.  Because store.@type is a value type, any consumer holding
   an older store.@type automatically retains all snapshots visible at
   that point â€” no manual reference counting needed.

   Methods summary
   ---------------
   Inspection (non-mutating):
     size()                        â†’ integer
     has(name)                     â†’ boolean
     version_count(name)           â†’ integer
     current_id(name)              â†’ string | null
     get(name)                     â†’ @? | null          (latest data)
     get_version(name, store_id)   â†’ @? | null          (specific version)
     get_ids(name)                 â†’ array.@type | null      (newest-first id list)

   Mutation (returns updated store.@type or [ store, store_id ] record):
     set(name, data)               â†’ [ store: store.@type, store_id: string ]
     register(name, data)          â†’ [ store: store.@type, store_id: string ]
     unregister(name)              â†’ store.@type
     prune_versions(name, keep)    â†’ store.@type

   Intrinsics used (UPPERCASE builtins):
     NEW_UUID_V7    â€” time-ordered unique id (UUIDv7)
     LENGTH<val>    â€” length of an array.@type
   ============================================================ *)

(col : std.collections.type.@type)  store: {
    names, n, 1..m: ["store"]
    map:     col.map
    filter:  col.filter
    reduce:  col.reduce
    count:   col.count
    first:   col.first
    last:    col.last
    collect: col.collect
    - (
        card,  c:       1..1
        type,  t:       $
        ver,   v:       "v0.0"

        (* Three typed hmap.@type fields replace untyped {} â€” satisfies Rule A.
           Each field is a distinct hmap instance initialised empty.
             current_ids  :  name      â†’ store_id (string)
             versions     :  store_id  â†’ [ data: @? ]
             name_ids     :  name      â†’ array.@type of store_ids, newest first *)
        current_ids: hmap []
        versions:    hmap []
        name_ids:    hmap []

        init: <- (
            <- [
                names:       __ps_call LHS Â§assign_lhs.ident_name,
                card:        __ps_call LHS Â§assign_lhs.cardinality,
                type:        $,
                current_ids: hmap [],
                versions:    hmap [],
                name_ids:    hmap []
            ]
        )
    )


    (* ---------------------------------------------------------------
       Inspection â€” all non-mutating
       --------------------------------------------------------------- *)

    (* size â€” number of distinct names registered in the store. *)
    (s : store.@type) size: <- (
        <- s.current_ids.size()
    )

    (* has â€” true when name has at least one stored version. *)
    (s : store.@type) has: <- (
        -> name: string
        <- s.current_ids.has(name)
    )

    (* version_count â€” number of stored snapshots for name.
       Returns 0 when name is not registered. *)
    (s : store.@type) version_count: <- (
        -> name: string
        ( ! s.name_ids.has(name) ) & <- 0
        <- __ps_proxy LENGTH <s.name_ids.get(name)>
    )

    (* current_id â€” most-recently stored UUIDv7 for name.
       Returns null when name is not registered. *)
    (s : store.@type) current_id: <- (
        -> name: string
        <- s.current_ids.get(name)
    )

    (* get_ids â€” newest-first list of all store_ids for name.
       Returns null when name is not registered. *)
    (s : store.@type) get_ids: <- (
        -> name: string
        <- s.name_ids.get(name)
    )

    (* get â€” retrieve data from the most-recent snapshot for name.
       Returns null when name is not registered. *)
    (s : store.@type) get: <- (
        -> name: string
        ( ! s.current_ids.has(name) ) & <- null
        sid: s.current_ids.get(name)
        ( ! s.versions.has(sid) ) & <- null
        <- s.versions.get(sid).data
    )

    (* get_version â€” retrieve data from a specific snapshot.
       Returns null when name or store_id is not found. *)
    (s : store.@type) get_version: <- (
        -> name:     string
        -> store_id: string
        ( ! s.current_ids.has(name) ) & <- null
        ( ! s.versions.has(store_id) ) & <- null
        <- s.versions.get(store_id).data
    )


    (* ---------------------------------------------------------------
       Mutation â€” each method returns a new store.@type (or a record)
       --------------------------------------------------------------- *)

    (* set â€” store a new versioned snapshot of data under name.
       Generates a UUIDv7 store_id for the snapshot.
       Returns [ store: store.@type, store_id: string ] so the caller can
       record the id if needed.  Replace your store.@type reference with
       the returned store field. *)
    (s : store.@type) set: <- (
        -> name: string
        -> data: @?
        sid:         __ps_proxy NEW_UUID_V7
        entry:       [ data: data ]
        new_versions: s.versions.put(sid, entry)
        new_current:  s.current_ids.put(name, sid)
        prev_ids:     s.name_ids.has(name) & s.name_ids.get(name) ^ []
        new_name_ids: s.name_ids.put(name, [sid] + prev_ids)
        <- [
            store: [
                type:        $,
                current_ids: new_current,
                versions:    new_versions,
                name_ids:    new_name_ids
            ],
            store_id: sid
        ]
    )

    (* register â€” alias for set; use when first creating a named slot.
       Re-registering an existing name adds a new version (no error). *)
    (s : store.@type) register: <- (
        -> name: string
        -> data: @?
        <- s.set(name, data)
    )

    (* unregister â€” remove all snapshots of name from the store.
       Returns s unchanged when name is not registered. *)
    (s : store.@type) unregister: <- (
        -> name: string
        ( ! s.current_ids.has(name) ) & <- s
        ids:         s.name_ids.get(name)
        new_versions = s.versions
        ids >> (
            >> sid: string
            new_versions = new_versions.remove(sid)
        )
        <- [
            type:        $,
            current_ids: s.current_ids.remove(name),
            versions:    new_versions,
            name_ids:    s.name_ids.remove(name)
        ]
    )

    (* prune_versions â€” keep only the most-recent keep snapshots for name
       and discard older ones.  Returns s unchanged when name is not
       registered or keep >= current version count.
       Useful for controlling memory growth in long-running stores. *)
    (s : store.@type) prune_versions: <- (
        -> name: string
        -> keep: integer
        ( ! s.name_ids.has(name) ) & <- s
        ids: s.name_ids.get(name)
        ( __ps_proxy LENGTH <ids> <= keep ) & <- s
        keep_ids:    ids.sub_array(1, keep)
        discard_ids: ids.sub_array(keep + 1, __ps_proxy LENGTH <ids>)
        new_versions = s.versions
        discard_ids >> (
            >> sid: string
            new_versions = new_versions.remove(sid)
        )
        <- [
            type:        $,
            current_ids: s.current_ids.put(name, keep_ids[1]),
            versions:    new_versions,
            name_ids:    s.name_ids.put(name, keep_ids)
        ]
    )
}
