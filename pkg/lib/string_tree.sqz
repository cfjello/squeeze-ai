(* ============================================================
   pkg/lib/string_tree.sqz  --  Squeeze V13 String Tree Type
   ============================================================

   Defines the string_tree.@type type and its methods.
   A string_tree is structurally identical to tree.@type but the grammar
   enforces that every node value is a string literal or a binding
   of type string.  No explicit `type` field is needed.

   All methods return new values; none mutate in place.

   Node shape (internal):  [ value: string, children: [] ]
   Tree shape (internal):  [ root: node | null ]

   The path_to result is an array.@type of string node values from the
   root down to (and including) the first node matching the target.

   Intrinsics used (UPPERCASE builtins):
     TREE_NODE_COUNT<t>           â€” total number of nodes
     TREE_DEPTH<t>                â€” max depth from root to any leaf
     TREE_ROOT_VALUE<t>           â€” value at the root node
     TREE_CHILDREN_COUNT<t>       â€” number of direct root children
     TREE_DFS<t>                  â€” array.@type of string values in DFS pre-order
     TREE_BFS<t>                  â€” array.@type of string values in BFS level-order
     TREE_WITH_CHILD<t, node>     â€” new string_tree: node appended as root child
     TREE_TO_JSON<t>              â€” JSON representation
     TREE_TO_STRING<t>            â€” indented text representation
     TREE_CONTAINS<t, value>      â€” boolean: any node equals value
     TREE_FIND_STR<t, value>      â€” first string value matching, or null
     TREE_PATH_TO<t, value>       â€” array.@type path of strings from root to first match
     TREE_TO_PATHS<t>             â€” array.@type of array.@type (each root-to-leaf path)
   *)

(col : std.collections.type.@type)  string_tree, string_tree_final: {
    names, n, 1..m: ["string_tree", "string_tree_final"]
    map:     col.map
    filter:  col.filter
    first:   col.first
    last:    col.last
    count:   col.count
    collect: col.collect
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       [ root: null ]
        ver,   v:       "v0.0"

        init: <- (
            -> raw: Â§string_tree_final
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name,
                 card:  __ps_call LHS Â§assign_lhs.cardinality,
                 type:  $,
                 data:  raw ]
        )
    )


    (* ---------------------------------------------------------------
       Structural inspection
       --------------------------------------------------------------- *)

    (* node_count â€” total number of nodes in the tree. *)
    (t : string_tree.@type) node_count: <- (
        <- __ps_proxy TREE_NODE_COUNT <t>
    )

    (* depth â€” maximum depth from root to any leaf.  Root alone = 1. *)
    (t : string_tree.@type) depth: <- (
        <- __ps_proxy TREE_DEPTH <t>
    )

    (* is_empty â€” true when the tree has no root node. *)
    (t : string_tree.@type) is_empty: <- (
        <- t.data.root == null
    )

    (* root_value â€” the string value at the root node. *)
    (t : string_tree.@type) root_value: <- (
        <- __ps_proxy TREE_ROOT_VALUE <t>
    )

    (* children_count â€” number of direct children of the root node. *)
    (t : string_tree.@type) children_count: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t>
    )

    (* is_leaf â€” true when the root has no children. *)
    (t : string_tree.@type) is_leaf: <- (
        <- __ps_proxy TREE_CHILDREN_COUNT <t> == 0
    )


    (* ---------------------------------------------------------------
       Traversal
       --------------------------------------------------------------- *)

    (* to_depth_first â€” array.@type of string values in DFS pre-order. *)
    (t : string_tree.@type) to_depth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_DFS <t> ]
    )

    (* to_breadth_first â€” array.@type of string values in BFS level-order. *)
    (t : string_tree.@type) to_breadth_first: <- (
        <- [ type: $, data: __ps_proxy TREE_BFS <t> ]
    )


    (* ---------------------------------------------------------------
       Search
       --------------------------------------------------------------- *)

    (* contains â€” true if any node in the tree holds exactly value. *)
    (t : string_tree.@type) contains: <- (
        -> value: string
        <- __ps_proxy TREE_CONTAINS <t, value>
    )

    (* find â€” first node value (DFS) that equals value, or null if absent. *)
    (t : string_tree.@type) find: <- (
        -> value: string
        <- __ps_proxy TREE_FIND_STR <t, value>
    )

    (* path_to â€” array.@type of string values along the path from the root
       down to (and including) the first node matching value.
       Returns an empty array when value is not present. *)
    (t : string_tree.@type) path_to: <- (
        -> value: string
        <- [ type: $, data: __ps_proxy TREE_PATH_TO <t, value> ]
    )


    (* ---------------------------------------------------------------
       Path enumeration
       --------------------------------------------------------------- *)

    (* to_paths â€” array.@type of array.@type; each inner array is the sequence of
       string values on one root-to-leaf path, ordered root-first. *)
    (t : string_tree.@type) to_paths: <- (
        <- [ type: $, data: __ps_proxy TREE_TO_PATHS <t> ]
    )

    (* to_paths_joined â€” array.@type of string; each element is one
       root-to-leaf path with node values joined by sep.
       Useful for rendering file-systemâ€“like path strings. *)
    (t : string_tree.@type) to_paths_joined: <- (
        -> sep: string
        paths = t.to_paths
        result = []
        >> path: paths.data
            joined = ""
            first  = true
            >> node: path
                joined = first & node ^ (joined + sep + node)
                first  = false
            result = result + [ joined ]
        <- [ type: $, data: result ]
    )


    (* ---------------------------------------------------------------
       Functional mutation
       --------------------------------------------------------------- *)

    (* with_child â€” new string_tree with node appended as a root child. *)
    (t : string_tree.@type) with_child: <- (
        -> node: @?
        <- [ type: $, data: __ps_proxy TREE_WITH_CHILD <t, node> ]
    )


    (* ---------------------------------------------------------------
       Conversion
       --------------------------------------------------------------- *)

    (* to_json â€” JSON object representation of the full tree. *)
    (t : string_tree.@type) to_json: <- (
        <- __ps_proxy TREE_TO_JSON <t>
    )

    (* to_string â€” indented text representation; children are indented
       two spaces per level below their parent. *)
    (t : string_tree.@type) to_string: <- (
        <- __ps_proxy TREE_TO_STRING <t>
    )
}
