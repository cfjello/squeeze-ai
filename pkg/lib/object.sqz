(* ============================================================
   pkg/lib/object.sqz  --  Squeeze V13 Object Type
   ============================================================

   Defines the object.@type type (associative array: string keys â†’ @? values)
   and its key-based methods.

   Key order is undefined at the Go runtime level (Go maps are unordered).
   All methods that return or iterate keys yield them in sorted order for
   deterministic, reproducible behaviour.

   To use collection-generic operations (map, filter, reduce, â€¦) over an
   object's contents, convert first:
     obj.get_values()   â€” iterator of values (key-sorted order)
     obj.to_array()     â€” iterator of [key: k, value: v] records

   Intrinsics used (UPPERCASE builtins):
     LENGTH<obj>                  â€” count of key-value pairs
     OBJ_HAS<obj, key>            â€” O(1) boolean key-presence check
     OBJ_KEYS<obj>                â€” sorted array.@type of all keys
     OBJ_VALUES<obj>              â€” array.@type of values in key-sorted order
     OBJ_TO_ARRAY<obj>            â€” array.@type of [key: k, value: v] records
     OBJ_WITH_KEY<obj, key, val>  â€” new object.@type with key â†’ val upserted
     OBJ_WITHOUT_KEY<obj, key>    â€” new object.@type with key removed
     TO_JSON<val>                 â€” JSON-serialise a single value
   *)

(col : std.collections.type.@type)  object, object_final: {
    names: ["object", "object_final"]
    map:     col.map
    filter:  col.filter
    reduce:  col.reduce
    count:   col.count
    collect: col.collect
    - (
        card,  c:       1..1
        type,  t:       $
        data,  d:       @?     (* raw associative map; assigned by init from Â§object_final *)
        ver,   v:       "v0.0"

        init: <- (
            -> raw: Â§object_final
            <- [ names: __ps_call LHS Â§assign_lhs.ident_name,
                 card:  __ps_call LHS Â§assign_lhs.cardinality,
                 type:  $,
                 data:  raw ]
        )
    )


    (* ---------------------------------------------------------------
       O(1) access
       --------------------------------------------------------------- *)

    (* length â€” number of key-value pairs. *)
    (obj : object.@type) length: <- (
        <- __ps_proxy LENGTH <obj.data>
    )

    (* contains_key â€” O(1) hash check; true when key is present. *)
    (obj : object.@type) contains_key: <- (
        -> key: string
        <- __ps_proxy OBJ_HAS <obj.data, key>
    )

    (* get â€” safe key access; returns default when the key is absent.
       Avoids a guarded double-lookup at every call site. *)
    (obj : object.@type) get: <- (
        -> key:     string
        -> default: @?
        ( __ps_proxy OBJ_HAS <obj.data, key> ) & <- obj.data[key]
        <- default
    )


    (* ---------------------------------------------------------------
       Projection
       --------------------------------------------------------------- *)

    (* get_keys â€” array.@type of all keys in sorted order.
       Sorted order guarantees repeatable iteration and JSON output. *)
    (obj : object.@type) get_keys: <- (
        <- __ps_proxy OBJ_KEYS <obj.data>
    )

    (* get_values â€” array.@type of all values ordered by sorted key.
       Use this as the input to collection pipelines when only values
       are needed. *)
    (obj : object.@type) get_values: <- (
        <- __ps_proxy OBJ_VALUES <obj.data>
    )

    (* to_array â€” converts to an array.@type of [key: k, value: v] records
       in sorted key order.  Enables full collection-generic pipelines
       over key-value pairs via collections.sqz. *)
    (obj : object.@type) to_array: <- (
        <- __ps_proxy OBJ_TO_ARRAY <obj.data>
    )


    (* ---------------------------------------------------------------
       Serialisation
       --------------------------------------------------------------- *)

    (* to_json â€” JSON object string: '{"k1": v1, "k2": v2, ...}'.
       Keys are emitted in sorted order for deterministic output.
       Delegates value formatting to TO_JSON<> for correct quoting. *)
    (obj : object.@type) to_json: <- (
        keys:  obj.get_keys()
        result = "{"
        first  = true
        keys >> (
            >> key: string
            sep_now = first & "" ^ ", "
            ( first ) & first = false
            result = result + sep_now + __ps_proxy TO_JSON <key> + ": " + __ps_proxy TO_JSON <obj.data[key]>
        )
        result = result + "}"
        <- result
    )


    (* ---------------------------------------------------------------
       Functional mutation â€” return a new object.@type, never mutates obj
       --------------------------------------------------------------- *)

    (* with_key â€” new object.@type with key â†’ val upserted.
       Adds the key when absent; replaces the value when present. *)
    (obj : object.@type) with_key: <- (
        -> key: string
        -> val: @?
        <- [ type: $, data: __ps_proxy OBJ_WITH_KEY <obj.data, key, val> ]
    )

    (* without_key â€” new object.@type with key removed.
       Returns obj unchanged when key is not present. *)
    (obj : object.@type) without_key: <- (
        -> key: string
        ( ! __ps_proxy OBJ_HAS <obj.data, key> ) & <- obj
        <- [ type: $, data: __ps_proxy OBJ_WITHOUT_KEY <obj.data, key> ]
    )
}
