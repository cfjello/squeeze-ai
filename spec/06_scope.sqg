(* V10 - read ./00_directives.sqg for Parser Instructions *)

include "./05_json_path.sqg";

import_assign  = assign_lhs assign_immutable ( HTTP_EXISTS<http_url> | FILE_EXISTS<file_path> );

scope_assign   = assign_lhs equal_assign "<" scope_entry ">" EOL;


extent_scope_oper = "+~" 

