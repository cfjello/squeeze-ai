scope_begin        = "{";
scope_end           = "}";

  
scope_entry    = import_assign { ( EOL | "," ) import_assign } [","]
                 assignment_v4 { ( EOL | "," )  ( assignment | scope_assign ) };

file_top_level = scope_assign;